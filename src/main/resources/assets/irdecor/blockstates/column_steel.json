{
  "multipart": [
    { "apply": { "model": "irdecor:block/pillar/catwalk_column_steel_base" } },
    { "when": { "down": "true" }, "apply": { "model": "irdecor:block/pillar/catwalk_column_steel_down" } },
    { "when": { "north": "true" }, "apply": { "model": "irdecor:block/pillar/catwalk_column_steel_side" } },
    { "when": { "south": "true" }, "apply": { "model": "irdecor:block/pillar/catwalk_column_steel_side", "y": 180 } },
    { "when": { "east": "true" }, "apply": { "model": "irdecor:block/pillar/catwalk_column_steel_side", "y": 270 } },
    { "when": { "west": "true" }, "apply": { "model": "irdecor:block/pillar/catwalk_column_steel_side", "y": 90 } }
  ]
}
