{
  "multipart": [
    { "apply": { "model": "irdecor:block/catwalk_base" } },
    { "when": { "down": "true" }, "apply": { "model": "irdecor:block/catwalk_down" } },
    { "when": { "up": "true" }, "apply": { "model": "irdecor:block/catwalk_up" } },
    { "when": { "north": "true" }, "apply": { "model": "irdecor:block/catwalk_side" } },
    { "when": { "south": "true" }, "apply": { "model": "irdecor:block/catwalk_side", "y": 180 } },
    { "when": { "east": "true" }, "apply": { "model": "irdecor:block/catwalk_side", "y": 270 } },
    { "when": { "west": "true" }, "apply": { "model": "irdecor:block/catwalk_side", "y": 90 } }
  ]
}
