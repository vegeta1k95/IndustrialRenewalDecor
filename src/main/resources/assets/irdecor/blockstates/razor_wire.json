{
  "multipart": [
    { "when": { "facing": "north" }, "apply": { "model": "irdecor:block/razor_wire" } },
    { "when": { "facing": "south" }, "apply": { "model": "irdecor:block/razor_wire", "y": 180 } },
    { "when": { "facing": "west" }, "apply": { "model": "irdecor:block/razor_wire", "y": 90 } },
    { "when": { "facing": "east" }, "apply": { "model": "irdecor:block/razor_wire", "y": 270 } },
    { "when": { "frame": "true" }, "apply": { "model": "irdecor:block/razor_wire_r" } }
  ]
}
