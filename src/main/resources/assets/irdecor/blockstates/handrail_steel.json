{
  "multipart": [
    { "when": { "facing": "north" }, "apply": { "model": "irdecor:block/catwalk_steel_side" } },
    { "when": { "facing": "south" }, "apply": { "model": "irdecor:block/catwalk_steel_side", "y": 180 } },
    { "when": { "facing": "west" }, "apply": { "model": "irdecor:block/catwalk_steel_side", "y": 90 } },
    { "when": { "facing": "east" }, "apply": { "model": "irdecor:block/catwalk_steel_side", "y": 270 } },
    { "when": { "down": "true" }, "apply": { "model": "irdecor:block/handrail_down" } }
  ]
}
